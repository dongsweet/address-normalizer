# Database
POSTGRES_DB=address_normalizer
POSTGRES_USER=address
POSTGRES_PASSWORD=address
DATABASE_URL=postgresql://address:address@db:5432/address_normalizer

# App
AUTO_INIT_DB=true
AUTO_SEED_PUBLIC_POI=true
PUBLIC_POI_CSV=/app/data/public_poi/urumqi_overture_poi_sample.csv
DEFAULT_CITY=乌鲁木齐市
CANDIDATE_LIMIT=8
MAX_BATCH_CONCURRENCY=4
FAST_PATH_ENABLED=true
FAST_PATH_SCORE=0.9
FAST_PATH_GAP=0.12
MEMORY_FAST_PATH_SCORE=0.82
STANDARD_FAST_PATH_SCORE=0.84
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Existing Qwen vLLM OpenAI-compatible API
QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_MODEL=qwen3.6-27b

# Optional MGeo worker
MGEO_ENABLED=false
MGEO_URL=http://mgeo:8090
MGEO_TIMEOUT_SECONDS=60
MGEO_MODEL_ID=iic/mgeo_geographic_elements_tagging_chinese_base
MGEO_MODEL_REVISION=
MGEO_LOAD_ON_STARTUP=true
MGEO_USE_MODEL=true

# Optional map API
MAP_API_ENABLED=false
MAP_PROVIDER=none
AMAP_KEY=
BAIDU_AK=
TENCENT_KEY=

# Frontend dev proxy inside docker compose
VITE_API_PROXY_TARGET=http://api:8000
