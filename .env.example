# Database
POSTGRES_DB=address_normalizer
POSTGRES_USER=address
POSTGRES_PASSWORD=address
# Keep DATABASE_URL in sync with POSTGRES_*.
# POSTGRES_* initialize the db container; DATABASE_URL is used by the api container.
DATABASE_URL=postgresql://address:address@db:5432/address_normalizer

# App
AUTO_INIT_DB=true
AUTO_SEED_PUBLIC_POI=true
PUBLIC_POI_CSV=/app/data/public_poi/urumqi_overture_poi_sample.csv
RECALL_SCOPE_MODE=auto
DEFAULT_CITY=
CANDIDATE_LIMIT=8
MAX_BATCH_CONCURRENCY=4
FAST_PATH_ENABLED=true
FAST_PATH_SCORE=0.95
FAST_PATH_GAP=0.12
MEMORY_FAST_PATH_SCORE=0.94
STANDARD_FAST_PATH_SCORE=0.96
CORS_ORIGINS=http://localhost:5173

# Existing Qwen vLLM OpenAI-compatible API
QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_MODEL=qwen3.6-27b

# Standard address source: hive for local simulated Hive, doris for Doris/MySQL protocol.
STANDARD_ADDRESS_SOURCE=hive

# Hive standard address source (local development default)
HIVE_ENABLED=true
HIVE_HOST=hive
HIVE_PORT=10000
HIVE_DATABASE=default
HIVE_TABLE=ysk_datahub_address_standed
HIVE_USERNAME=hive
HIVE_PASSWORD=changeme
HIVE_AUTH_MECHANISM=PLAIN
HIVE_QUERY_TIMEOUT_SECONDS=8
HIVE_FETCH_LIMIT=20

# Doris standard address source (preferred for intranet delivery)
DORIS_ENABLED=false
DORIS_HOST=doris-fe
DORIS_PORT=9030
DORIS_DATABASE=address_normalizer
DORIS_TABLE=ysk_datahub_address_standed
DORIS_USERNAME=root
DORIS_PASSWORD=
DORIS_QUERY_TIMEOUT_SECONDS=8
DORIS_FETCH_LIMIT=20

# Optional MGeo worker
MGEO_ENABLED=false
MGEO_URL=http://mgeo:8090
MGEO_TIMEOUT_SECONDS=60
MGEO_MODEL_ID=iic/mgeo_geographic_elements_tagging_chinese_base
MGEO_MODEL_REVISION=
MGEO_LOAD_ON_STARTUP=true
MGEO_USE_MODEL=true

# API quotas (optional - set to enable daily/monthly limits)
# QWEN_DAILY_QUOTA=500
# QWEN_MONTHLY_QUOTA=15000

# Frontend dev proxy inside docker compose
VITE_API_PROXY_TARGET=http://api:8000
