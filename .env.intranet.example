# Database
POSTGRES_DB=address_normalizer
POSTGRES_USER=address
POSTGRES_PASSWORD=address
# This intranet package assumes Linux Docker host networking.
# Keep DATABASE_URL in sync with POSTGRES_*.
DATABASE_URL=postgresql://address:address@127.0.0.1:5432/address_normalizer

# App
AUTO_INIT_DB=true
AUTO_SEED_PUBLIC_POI=false
PUBLIC_POI_CSV=/app/data/public_poi/urumqi_overture_poi_sample.csv
RECALL_SCOPE_MODE=auto
DEFAULT_CITY=
CANDIDATE_LIMIT=8
MAX_BATCH_CONCURRENCY=4
FAST_PATH_ENABLED=true
FAST_PATH_SCORE=0.95
FAST_PATH_GAP=0.12
MEMORY_FAST_PATH_SCORE=0.94
STANDARD_FAST_PATH_SCORE=0.96
# If frontend and api are deployed via the bundled intranet compose,
# browser traffic goes through frontend `/api` proxy and CORS is usually unnecessary.
# Keep localhost for same-host access, or replace with the real frontend origin if needed.
CORS_ORIGINS=http://localhost:5173

# Qwen (optional)
QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_MODEL=qwen3.6-27b

# Hive standard address source
HIVE_ENABLED=true
HIVE_HOST=your-hive-host
HIVE_PORT=10000
HIVE_DATABASE=default
HIVE_TABLE=ysk_datahub_address_standed
HIVE_USERNAME=
HIVE_PASSWORD=
HIVE_AUTH_MECHANISM=PLAIN
HIVE_QUERY_TIMEOUT_SECONDS=8
HIVE_FETCH_LIMIT=20

# Optional MGeo worker
MGEO_ENABLED=false
MGEO_URL=http://127.0.0.1:8090
MGEO_TIMEOUT_SECONDS=60
MGEO_MODEL_ID=iic/mgeo_geographic_elements_tagging_chinese_base
MGEO_MODEL_REVISION=
MGEO_LOAD_ON_STARTUP=true
MGEO_USE_MODEL=true

# Frontend
FRONTEND_PORT=5173
FRONTEND_API_PROXY_TARGET=http://127.0.0.1:8000
